{
    "name": "battle-piaf",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "build": "esbuild src/main.ts --bundle --outfile=public/dist/game.js",
        "watch": "esbuild src/main.ts --bundle --outfile=public/dist/game.js --watch",
        "dev": "esbuild src/main.ts --bundle --outfile=public/dist/game.js --platform=browser --watch --servedir=./public",
        "build-editor": "esbuild src/level-editor/main.ts --bundle --outfile=public/dist/level-editor.js",
        "dev-editor": "esbuild src/level-editor/main.ts --bundle --outfile=public/dist/level-editor.js --watch",
        "check": "tsc --noEmit",
        "lint": "eslint src/**/*.ts",
        "format": "prettier --write src/**/*.ts",
        "fix": "npm run format && npm run lint -- --fix"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/howler": "^2.2.12",
        "esbuild": "^0.25.0",
        "eslint": "^10.2.0",
        "eslint-config-prettier": "^10.1.8",
        "prettier": "^3.8.1",
        "typescript": "^5.8.0",
        "typescript-eslint": "^8.58.0"
    },
    "dependencies": {
        "howler": "^2.2.4",
        "petite-vue": "^0.4.1"
    }
}
